enum AssemblyStatus {
  DRAFT
  RUNNING
  COMPLETE
  ARCHIVED
}

enum SectionStatus {
  PENDING
  GENERATING
  COMPLETE
  FAILED
}

// ============================================
// SOCIAL MEDIA INTEGRATION MODELS
// Phase 4: Marketing Execution Architecture
// ============================================

model SocialAccount {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  platform      String   // "facebook" | "instagram" | "linkedin" | "tiktok" | "youtube" | "twitter"
  accountName   String   // display name
  accountId     String   // platform-specific account/page ID
  accessToken   String?  // encrypted OAuth token
  refreshToken  String?  // encrypted refresh token
  tokenExpiry   DateTime?
  scopes        String[] // granted OAuth scopes
  isActive      Boolean  @default(true)
  connectedAt   DateTime @default(now())
  connectedBy   String   // userId who connected
  metadata      Json?    // platform-specific data (page ID, channel ID, etc.)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  posts         SocialPost[]
  engagements   SocialEngagement[]

  @@unique([tenantId, platform, accountId])
  @@index([tenantId])
  @@map("social_accounts")
}

model SocialPost {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  socialAccountId String
  socialAccount   SocialAccount @relation(fields: [socialAccountId], references: [id])
  content         String   // post text
  mediaUrls       String[] // attached images/videos
  platformPostId  String?  // ID returned by platform after publishing
  status          String   @default("draft") // "draft" | "scheduled" | "pending_approval" | "published" | "failed"
  scheduledFor    DateTime?
  publishedAt     DateTime?
  approvedBy      String?  // userId who approved
  approvedAt      DateTime?
  campaignId      String?  // link to CMO campaign
  calendarEventId String?  // link to CMO calendar event
  metadata        Json?    // platform-specific data (hashtags, mentions, etc.)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  engagements     SocialEngagement[]

  @@index([tenantId])
  @@index([socialAccountId])
  @@index([status])
  @@index([scheduledFor])
  @@map("social_posts")
}

model SocialEngagement {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  socialAccountId String
  socialAccount   SocialAccount @relation(fields: [socialAccountId], references: [id])
  socialPostId    String?
  socialPost      SocialPost? @relation(fields: [socialPostId], references: [id])
  type            String   // "comment" | "reply" | "dm" | "mention" | "like" | "share"
  platformId      String   // platform-specific engagement ID
  authorName      String
  authorHandle    String?
  authorFollowers Int?     // for escalation rules
  content         String?  // the comment/message text
  sentiment       String?  // "positive" | "neutral" | "negative" | "unknown"
  status          String   @default("new") // "new" | "auto_replied" | "draft_reply" | "replied" | "escalated" | "ignored"
  replyContent    String?  // Don's drafted/sent reply
  replyStatus     String?  // "auto" | "pending_approval" | "approved" | "sent"
  escalationReason String? // why it was escalated
  respondedAt     DateTime?
  respondedBy     String?  // "don_auto" | userId
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@index([socialAccountId])
  @@index([status])
  @@index([type])
  @@map("social_engagements")
}

model DesignAsset {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  name          String
  type          String   // "image" | "video" | "graphic" | "template"
  source        String   // "canva" | "adobe" | "upload" | "ai_generated"
  sourceId      String?  // external tool asset ID
  fileUrl       String?  // stored file URL
  thumbnailUrl  String?
  dimensions    Json?    // { width, height }
  format        String?  // "png" | "jpg" | "mp4" | "svg"
  tags          String[]
  usedInPosts   String[] // socialPostIds where this asset was used
  campaignId    String?  // associated campaign
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([source])
  @@map("design_assets")
}

// ============================================
// CONSULTING MODULE MODELS
// Phase 5: Consulting & Professional Services
// ============================================

enum ConsultingStatus {
  ACTIVE
  COMPLETED
  PAUSED
}

enum DeliverableStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DELIVERED
}

enum EngagementStatus {
  ACTIVE
  COMPLETED
  PAUSED
  EXPIRED
}

model ConsultingEngagement {
  id              String            @id @default(cuid())
  tenantId        String
  packageType     String
  startDate       DateTime
  endDate         DateTime?
  status          EngagementStatus  @default(ACTIVE)
  totalHours      Float             @default(0)
  hoursUsed       Float             @default(0)
  billableHours   Float             @default(0)
  stripePaymentId String?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  tenant       Tenant                  @relation(fields: [tenantId], references: [id])
  timeEntries  ConsultingTimeEntry[]
  deliverables ConsultingDeliverable[]

  @@index([tenantId])
  @@index([status])
  @@map("consulting_engagements")
}

model ConsultingTimeEntry {
  id            String   @id @default(cuid())
  tenantId      String
  engagementId  String
  date          DateTime
  hours         Float
  billableHours Float    @default(0)
  description   String
  category      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant     Tenant               @relation(fields: [tenantId], references: [id])
  engagement ConsultingEngagement @relation(fields: [engagementId], references: [id])

  @@index([tenantId])
  @@index([engagementId])
  @@index([date])
  @@map("consulting_time_entries")
}

model ConsultingDeliverable {
  id           String            @id @default(cuid())
  tenantId     String
  engagementId String
  packageTier  String
  name         String
  description  String?
  status       DeliverableStatus @default(PENDING)
  deliveredAt  DateTime?
  documentUrl  String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  tenant     Tenant               @relation(fields: [tenantId], references: [id])
  engagement ConsultingEngagement @relation(fields: [engagementId], references: [id])

  @@index([tenantId])
  @@index([engagementId])
  @@index([status])
  @@map("consulting_deliverables")
}
