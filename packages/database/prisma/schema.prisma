  level       String   // L1, L2, L3, L4
  input       Json?    // Tool input parameters
  output      Json?    // Tool output/result
  success     Boolean  @default(true)
  errorMessage String?
  // Context
  tenantId    String?  // If tenant-scoped
  targetUserId String? // If user-scoped
  // Deployment specific
  deploymentTarget String? // frontend, backend, both
  deploymentVersion String?
  // Timestamps
  executedAt  DateTime @default(now())
  durationMs  Int?

  @@index([action])
  @@index([level])
  @@index([success])
  @@index([executedAt])
  @@index([tenantId])
  @@map("zander_action_logs")
}

