  type               AssemblyType
  cadence            AssemblyCadence @default(ONCE)
  status             AssemblyStatus  @default(DRAFT)
  scheduledFor       DateTime?
  completedAt        DateTime?
  treasuryTemplateId String?
  createdById        String
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  tenant   Tenant            @relation(fields: [tenantId], references: [id])
  sections AssemblySection[]

  @@index([tenantId])
  @@index([status])
  @@index([type])
  @@map("assemblies")
}

model AssemblySection {
  id          String        @id @default(cuid())
  assemblyId  String
  executive   String        // "jordan" | "don" | "pam" | "ben" | "miranda" | "ted" | "jarvis"
  title       String
  prompt      String        @db.Text
  content     String?       @db.Text
  status      SectionStatus @default(PENDING)
  order       Int
  generatedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  assembly Assembly @relation(fields: [assemblyId], references: [id], onDelete: Cascade)

  @@index([assemblyId])
  @@index([status])
  @@map("assembly_sections")
}

// ============================================
// HQ MODULE - GOALS (My Campaign, Quarterly, Annual)
// ============================================

model HQGoal {
  id           String    @id @default(cuid())
  tenantId     String
  title        String
  description  String?
  scope        String    // PERSONAL, QUARTERLY, ANNUAL
  status       String    @default("ACTIVE") // ACTIVE, COMPLETED, DEFERRED, CANCELLED
  priority     String?   // P1, P2, P3
  progress     Int       @default(0) // 0-100
  targetValue  Float?
  currentValue Float?
  ownerId      String?
  ownerName    String?
  dueDate      DateTime?
  quarter      String?   // Q1, Q2, Q3, Q4
  year         Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([scope])
  @@index([status])
  @@index([quarter, year])
  @@map("hq_goals")
}

// ============================================
// HQ MODULE - KEYSTONES (Executive Vital Signs)
// ============================================

model Keystone {
  id            String   @id @default(cuid())
  tenantId      String
  executive     String   // CRO, CFO, COO, CMO, CPO, CIO, EA — maps to AI executive
  label         String   // Display label e.g. "Pipeline Value", "Monthly Revenue"
  value         String   // Current value as string (allows "$139K", "94%", "4.2")
  numericValue  Float?   // Numeric version for trend calculations
  target        String?  // Target value as string
  numericTarget Float?   // Numeric target for progress calc
  trend         String?  // UP, DOWN, FLAT
  trendValue    String?  // e.g. "+12%", "-3%"
  color         String?  // Hex color for the card
  icon          String?  // Emoji or icon identifier
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([executive])
  @@map("keystones")
}

// ============================================
// HQ MODULE - LEDGER (Company/Team/Personal Metrics)
// ============================================

model LedgerEntry {
  id            String   @id @default(cuid())
  tenantId      String
  category      String   // COMPANY, TEAM, PERSONAL
  name          String   // Metric name
  keystone      String?  // Which executive owns this — links conceptually to Keystone.executive
  value         String   // Current value
  numericValue  Float?
  target        String?
  numericTarget Float?
  progress      Int?     // 0-100 calculated or manual
  trend         String?  // UP, DOWN, FLAT
  owner         String?  // Person responsible
  status        String   @default("ON_TRACK") // ON_TRACK, AT_RISK, BEHIND, EXCEEDED
  period        String?  // WEEKLY, MONTHLY, QUARTERLY, ANNUAL
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([category])
  @@index([status])
  @@map("ledger_entries")
}

// ============================================
// HQ MODULE - FOUNDING DOCUMENT (Vision/Mission/Values)
// ============================================

model FoundingDocument {
  id        String   @id @default(cuid())
  tenantId  String   @unique // One document per tenant - singleton pattern
  vision    String?  @db.Text
  mission   String?  @db.Text
  values    Json?    // Array of { title: string, description: string }
  story     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("founding_documents")
}

// ============================================
// HQ MODULE - LEGACY MILESTONES (3-5 Year Roadmap)
// ============================================

model LegacyMilestone {
  id          String   @id @default(cuid())
  tenantId    String
  year        Int      // 2026, 2027, 2028, etc.
  title       String
  description String?  @db.Text
  goals       Json?    // Array of { text: string, completed: boolean }
  progress    Int      @default(0) // 0-100
  status      String   @default("PLANNED") // PLANNED, IN_PROGRESS, COMPLETED, DEFERRED
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([year])
  @@index([status])
  @@map("legacy_milestones")
}
